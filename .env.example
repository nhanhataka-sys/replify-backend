WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
VERIFY_TOKEN=your_verify_token
ANTHROPIC_API_KEY=your_anthropic_api_key
DATABASE_URL=postgresql://user:password@host:port/dbname
ALLOWED_ORIGINS=https://your-frontend-domain.com
PORT=8000

# --- News Bulletin ---
# NewsAPI key from https://newsapi.org (free tier supported)
NEWS_API_KEY=your_newsapi_key

# X (Twitter) API credentials — requires Basic or higher access tier
# Create an app at https://developer.twitter.com and enable OAuth 1.0a read+write
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# Daily bulletin schedule (SAST = Africa/Johannesburg, UTC+2)
# Defaults to 08:00 SAST if not set
BULLETIN_HOUR=8
BULLETIN_MINUTE=0
