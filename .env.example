WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
VERIFY_TOKEN=your_verify_token
ANTHROPIC_API_KEY=your_anthropic_api_key
DATABASE_URL=postgresql://user:password@host:port/dbname
ALLOWED_ORIGINS=https://your-frontend-domain.com
PORT=8000

# --- News Bulletin ---
# No news API key needed — headlines are pulled from free RSS feeds
# (News24, TimesLive, Daily Maverick, BBC, Al Jazeera, Sky News)

# Comma-separated WhatsApp numbers to receive the daily bulletin (include country code, no +)
# Example: 27821234567,27831234567
BULLETIN_WHATSAPP_TO=27821234567

# Daily bulletin schedule (SAST = Africa/Johannesburg, UTC+2)
# Defaults to 08:00 SAST if not set
BULLETIN_HOUR=8
BULLETIN_MINUTE=0
